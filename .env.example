# -----------------------------------------------------------------------
# Webull OpenAPI credentials
# Apply at: https://developer.webull.com.my/apis/docs/authentication/individual-application
# Docs: https://developer.webull.com.my/apis/llms.txt
# -----------------------------------------------------------------------
WEBULL_APP_KEY=your_webull_app_key_here
WEBULL_APP_SECRET=your_webull_app_secret_here

# Region code — must match your Webull account region
# Options: my  us  sg  hk  jp  au  uk  br  mx  th
WEBULL_REGION_ID=my

# API host override (optional — leave blank to use the SDK default)
# Production MY: api.webull.com.my
# UAT/testing:   my-api.uat.webullbroker.com
WEBULL_API_HOST=
